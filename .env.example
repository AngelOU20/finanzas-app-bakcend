# Estado del entorno: local | production
ENV_STATE=local

# Modo debug (True solo en local)
DEBUG=True

# Clave secreta de Django (generá una nueva con: python -m secrets)
SECRET_KEY=django-insecure-change-me

# Hosts permitidos (JSON array)
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# Orígenes permitidos para CORS — URL donde corre el frontend (JSON array)
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# Base de datos MySQL
DB_NAME=finanzas_db
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
